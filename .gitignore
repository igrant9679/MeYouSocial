# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local data
/.data/
/prisma/dev.db
/prisma/dev.db-journal

# transient test artifacts (cookie jars, request bodies)
/.test-*

# local-only session handoff (contains Railway infra IDs; this repo is public)
/SESSION-HANDOFF.md

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
