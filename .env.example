# =============================================================================
# CreateUp — Environment Configuration (.env.example)
# -----------------------------------------------------------------------------
# Copy to ".env" and fill in. The app is designed to BOOT AND RUN with zero real
# keys by using mock providers (set the USE_MOCK_* flags = true). Turn each
# integration "on" by setting its flag false and supplying the credential.
#
# Legend:  [MVP]   needed for the core demo (real or mocked)
#          [LATER] only when you enable that feature
# Defaults assume: Next.js + TypeScript + PostgreSQL/Prisma + Auth.js.
# =============================================================================

# ---------------------------------------------------------------------------
# CORE APP                                                              [MVP]
# ---------------------------------------------------------------------------
NODE_ENV=development
APP_URL=http://localhost:3000           # public base URL (used for OAuth redirects, emails)
APP_NAME=CreateUp
# First admin bootstrapped on initial setup (the owner of the first workspace):
BOOTSTRAP_ADMIN_EMAIL=you@example.com
# Password for the seeded admin (prisma/seed.ts). Set this in prod so the seed
# doesn't fall back to — or log — the public dev default "createup-dev". Only
# applied when the admin is first created (for an existing admin, change it in-app
# via Settings → Change password).
SEED_ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# DATABASE (PostgreSQL via Prisma)                                     [MVP]
# ---------------------------------------------------------------------------
# Local default; or paste a managed connection string (Supabase/Neon/RDS/etc).
DATABASE_URL=postgresql://createup:createup@localhost:5432/createup

# ---------------------------------------------------------------------------
# AUTH (Auth.js / NextAuth) — individual logins + roles                [MVP]
# ---------------------------------------------------------------------------
AUTH_SECRET=                            # generate: `openssl rand -base64 32`
AUTH_URL=http://localhost:3000
# Email/password is built-in. Google SSO is optional but recommended (FR-AUTH-01):
ENABLE_GOOGLE_SSO=false
GOOGLE_CLIENT_ID=                       # Google Cloud Console > OAuth 2.0 Client
GOOGLE_CLIENT_SECRET=
# Authorized redirect URI to register in Google console:
#   ${APP_URL}/api/auth/callback/google

# ---------------------------------------------------------------------------
# AI MODEL PROVIDERS  (FR-MODEL-01..06)                                [MVP]
# ---------------------------------------------------------------------------
# All providers sit behind ONE routing layer; you only need the ones you want
# selectable. With USE_MOCK_LLM=true the app runs end-to-end with a fake model.
USE_MOCK_LLM=true
DEFAULT_LLM_MODEL=claude-sonnet         # default model id used by the router

ANTHROPIC_API_KEY=                      # Claude
OPENAI_API_KEY=                         # GPT
GOOGLE_GENAI_API_KEY=                   # Gemini
DEEPSEEK_API_KEY=                       # DeepSeek
XAI_API_KEY=                            # Grok
MOONSHOT_API_KEY=                       # Kimi
MINIMAX_API_KEY=                        # MiniMax
# (Provide at least one real key, or leave USE_MOCK_LLM=true.)

# ---------------------------------------------------------------------------
# IMAGE GENERATION — thumbnails + audience photos (FR-THUMB, FR-AUD-03) [LATER]
# ---------------------------------------------------------------------------
USE_MOCK_IMAGES=true
IMAGE_PROVIDER=                         # e.g. openai | stability | replicate | google
IMAGE_API_KEY=

# ---------------------------------------------------------------------------
# YOUTUBE DATA — Intel, voice/audience training, channel analysis      [MVP*]
# ---------------------------------------------------------------------------
# *Core to Intel/ideas. Use mock data first; supply a key to index real channels.
USE_MOCK_YOUTUBE=true
YOUTUBE_API_KEY=                        # Google Cloud Console > YouTube Data API v3
# Transcript fetching (if using a 3rd-party transcript service):
TRANSCRIPT_PROVIDER=
TRANSCRIPT_API_KEY=

# ---------------------------------------------------------------------------
# WEB SEARCH / AI RESEARCH (FR-CHAT-05/06)                             [LATER]
# ---------------------------------------------------------------------------
USE_MOCK_SEARCH=true
SEARCH_PROVIDER=                        # e.g. tavily | bing | serpapi | brave
SEARCH_API_KEY=

# ---------------------------------------------------------------------------
# FILE / ASSET STORAGE — uploads, B-roll, thumbnails, swipes           [MVP]
# ---------------------------------------------------------------------------
# Choose ONE backend. "local" works out of the box for development.
STORAGE_BACKEND=local                   # local | gdrive | s3
STORAGE_LOCAL_DIR=./.data/uploads       # used when STORAGE_BACKEND=local

# -- Google Drive (STORAGE_BACKEND=gdrive) -----------------------------------
GDRIVE_FOLDER_ID=                       # the Drive folder ID to store files in
GDRIVE_CLIENT_ID=
GDRIVE_CLIENT_SECRET=
GDRIVE_REFRESH_TOKEN=                   # OR a service-account JSON path below
GOOGLE_SERVICE_ACCOUNT_JSON=            # path to service-account key file (alt auth)

# -- S3-compatible bucket (STORAGE_BACKEND=s3) -------------------------------
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=                            # optional (for R2/MinIO/etc)

# ---------------------------------------------------------------------------
# BACKGROUND JOBS — long script gen, Agent Mode, indexing (FR-AGENT)   [MVP]
# ---------------------------------------------------------------------------
# Queue/worker backend. Redis recommended; "memory" is fine for a single-node dev run.
JOB_BACKEND=memory                      # memory | redis
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# EMAIL — invitations + "your script is ready" notices (FR-AUTH-04,    [LATER]
#         FR-AGENT-02)
# ---------------------------------------------------------------------------
USE_MOCK_EMAIL=true                     # mock prints emails to the console
EMAIL_PROVIDER=                         # e.g. resend | postmark | ses | smtp
EMAIL_API_KEY=
EMAIL_FROM="CreateUp <no-reply@example.com>"
# SMTP fallback (if EMAIL_PROVIDER=smtp):
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ---------------------------------------------------------------------------
# OPTIONAL VIDEO PRODUCTION — voiceover / avatar / render (FR-AGENT-05) [LATER]
# ---------------------------------------------------------------------------
USE_MOCK_PRODUCTION=true
TTS_PROVIDER=                           # e.g. elevenlabs
TTS_API_KEY=
AVATAR_PROVIDER=                        # e.g. heygen | did
AVATAR_API_KEY=
RENDER_PROVIDER=
RENDER_API_KEY=

# ---------------------------------------------------------------------------
# OPTIONAL SOFT LIMITS (admin-set, non-paid)  (FR-ADMIN-03)            [LATER]
# ---------------------------------------------------------------------------
# Defaults to unlimited. Set a number to cap; leave blank/0 for unlimited.
LIMIT_SCRIPTS_PER_USER_MONTH=
LIMIT_THUMBNAILS_PER_USER_MONTH=
LIMIT_AGENT_RUNS_PER_USER_MONTH=

# ---------------------------------------------------------------------------
# MISC / OBSERVABILITY                                                 [LATER]
# ---------------------------------------------------------------------------
LOG_LEVEL=info
RATE_LIMIT_PER_MINUTE=60                 # per-user chat/generation guard (NFR-SCALE-02)
# SENTRY_DSN=
