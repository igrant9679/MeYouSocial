// MeYouSocial — data model. Mirrors §10 "Conceptual Data Model" of the spec.
//
// PostgreSQL for both local dev and Railway prod (see DECISIONS.md §1).
// JSON-shaped fields remain String (serialized JSON) so the data model is
// portable; helpers in src/lib/db/json.ts handle parse/stringify.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────────────────────────────────
// Auth / workspace / users (FR-AUTH-*, FR-ADMIN-*)
// ──────────────────────────────────────────────────────────────────────────

model Workspace {
  id              String   @id @default(cuid())
  name            String
  // Defaults for new channels
  defaultChannelId String? @unique
  defaultModel    String?  // e.g. "claude-sonnet"
  defaultLanguage String   @default("en")
  // FR-ADMIN-03 optional soft limits — null/0 = unlimited
  limitScriptsPerUserMonth     Int?
  limitThumbnailsPerUserMonth  Int?
  limitAgentRunsPerUserMonth   Int?
  limitChannels                Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Per-company app-chrome branding (multi-tenant): accent hue drives the CSS
  // token overrides in the app shell; logoKey is a StoredFile key.
  accentColor     String?
  logoKey         String?

  memberships     Membership[]
  channels        Channel[]
  invitations     Invitation[]
  bookmarks       Bookmark[]
  usageLogs       UsageLog[]
  tasks           Task[]
  swipes          Swipe[]
  wikiDocs        WikiDoc[]
  blogPosts       BlogPost[]
  settings        WorkspaceSetting[]
  unipileAccounts UnipileAccount[]
  socialPosts     SocialPost[]
  topics          Topic[]
}

// ---- Blog (ported from Spark's article pipeline; slice 1) --------------------
// Workspace-scoped blog posts with Spark's review-state machine and SEO fields.
// Later slices add citations, WCAG/SEO gates, WordPress publish, analytics.
model BlogPost {
  id              String    @id @default(cuid())
  workspaceId     String
  title           String
  // drafting | draft_review | final_approval | published (scheduled comes with WP publish)
  status          String    @default("drafting")
  body            String?   // HTML draft
  slug            String?
  metaTitle       String?
  metaDescription String?
  focusKeyword    String?
  audience        String?
  wordCountTarget Int?
  publishedUrl    String?
  publishedAt     DateTime?
  // Spark FR-14: shield a high performer from disruptive regeneration.
  protectedFromRewrite Boolean @default(false)
  // Wave A′ SEO fields
  secondaryKeywords String  @default("[]") // JSON array of phrases
  outline         String?   // JSON [{heading, points[]}] — outline-first drafting
  tone            String?   // DEPRECATED — superseded by `motifs` (FR-2); kept so old rows keep their value
  // FR-2: weighted motif selection — JSON [{key, weight}] summing to 100.
  // Empty array = fall back to the workspace motif defaults for this tier/audience.
  motifs          String    @default("[]")
  contentTier     Int?      // 1 = head … 4 = long-tail; drives the motif default lookup
  readingLevel    String?   // simple | standard | advanced
  scheduledAt     DateTime? // publish-at time; setting it at final_approval is the human approval
  templateKey     String?   // blog structure template (listicle, how-to, ...)
  model           String?   // per-post model override (multi-model drafting)
  eeatReview      String?   // JSON — last E-E-A-T review findings
  // FR-7 publish fidelity: canonical + explicit OG overrides (OG image is the
  // BlogImage row with role="og"). Empty OG fields fall back to the meta pair.
  canonicalUrl    String?
  ogTitle         String?
  ogDescription   String?
  categories      String    @default("[]") // JSON array of WP category names
  tags            String    @default("[]") // JSON array of WP tag names
  publisherNotes  String?   // FR-7 "notes for the publisher"
  topicId         String?   // optional workspace Topic this post belongs to
  smeProfileId    String?   // FR-3: the expert this draft speaks as
  reviewerId      String?   // FR-10: who owns the review of this draft
  wpPostId        Int?      // set on publish; lets a later slice update in place
  // JSON — what WordPress actually accepted on the last publish, read back from
  // the API. We report the truth rather than assuming the payload landed.
  publishReport   String?
  createdById     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  // Deleting a topic must not delete the posts that referenced it.
  topic     Topic?         @relation(fields: [topicId], references: [id], onDelete: SetNull)
  citations BlogCitation[]
  comments  BlogComment[]
  images    BlogImage[]
  variants  SocialVariant[]
  snapshots BlogSnapshot[]
  versions  BlogPostVersion[]

  @@index([workspaceId, status])
}

// Version history — snapshot on every generation and manual save.
model BlogPostVersion {
  id        String   @id @default(cuid())
  postId    String
  label     String   // "generated", "saved", "restored from ..."
  body      String?
  createdAt DateTime @default(now())

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
}

// Keyword strategy (Spark's 4-tier table, extended with clusters + intent).
// Volume/difficulty are NOT stored — we have no search-data source; intent and
// clusters are LLM-classified and labeled as such in the UI.
model Keyword {
  id          String   @id @default(cuid())
  workspaceId String
  phrase      String
  tier        Int      @default(3) // 1 = head ... 4 = long-tail
  intent      String?  // informational | commercial | transactional | navigational
  cluster     String?  // topical cluster name
  notes       String?
  status      String   @default("active") // active | paused
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([workspaceId, phrase])
  @@index([workspaceId, cluster])
}

// Site page inventory for internal-link suggestions (Spark's link graph seed).
model SitePage {
  id          String   @id @default(cuid())
  workspaceId String
  url         String
  title       String
  topic       String?  // short description of what the page covers
  createdAt   DateTime @default(now())

  @@unique([workspaceId, url])
}

// Spark's org profile — "what this client does"; grounds every generation.
model OrgProfile {
  id          String   @id @default(cuid())
  workspaceId String   @unique
  description String?  // what they do, for whom, differentiation
  industry    String?
  services    String   @default("[]") // JSON array of strings
  audience    String?
  updatedAt   DateTime @updatedAt
}

// ---- FR-2: brand kit, typography & the 7 Motifs tone engine ------------------

// Per-workspace brand kit. Heading spec + image dimensions are article-scoped
// visual settings, deliberately independent of the connected site's theme.
model BrandKit {
  id             String  @id @default(cuid())
  workspaceId    String  @unique
  primaryColor   String? // hex — the workspace's own brand, not the app's hue tokens
  secondaryColor String?
  accentColor    String?
  headingFont    String?
  bodyFont       String?
  logoUrl        String?
  footerCredit   String?
  toneGuardrails String? // "never say X", house style notes — injected into every generation
  // JSON {h1..h6: {px, marginTop, marginBottom, weight?, lineHeight?, color?}}
  headingSpec    String  @default("{}")
  featuredImageWidth  Int @default(1920)
  featuredImageHeight Int @default(1080)
  ogImageWidth        Int @default(1200)
  ogImageHeight       Int @default(630)
  // FR-18 design-system rendering profile
  renderProfile  String  @default("html") // html | gutenberg | fusion
  renderRules    String  @default("{}")   // JSON toggles per content pattern
  // FR-8 asset policy
  requireImagesToPublish Boolean @default(true)  // featured + OG required before publish
  aiImagesEnabled        Boolean @default(false) // AI generation, always human-reviewed
  brandInBodyImages      Boolean @default(false) // OG is always branded; opt in for the rest
  updatedAt      DateTime @updatedAt
}

// FR-8: an article needs a featured image and a branded Open Graph image, both
// at the workspace's pixel dimensions, both with alt text. AI-generated images
// stay `pending` until a human approves them — they never satisfy the gate on
// their own.
model BlogImage {
  id        String   @id @default(cuid())
  postId    String
  role      String   // featured | og
  url       String
  altText   String?
  width     Int?     // measured from the file, not typed by hand
  height    Int?
  source    String   @default("url") // url | upload | ai
  status    String   @default("approved") // pending | approved
  branded   Boolean  @default(false)
  brief     String?  // the image brief this asset was produced against
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, role])
}

// The 7 Motifs as editable, versioned style directives (never hard-coded prompt
// text). Seeded per workspace from the LSI framework defaults on first use.
model MotifDirective {
  id          String   @id @default(cuid())
  workspaceId String
  key         String   // visionary | competitive | succinct | sincere | exclusive | social | informative
  label       String
  summary     String   // one-line description shown in the picker
  voice       String   // voice signature
  rhythm      String   // sentence rhythm / structure
  evidence    String   // what counts as evidence in this motif
  cta         String   // CTA pattern
  version     Int      @default(1)
  updatedAt   DateTime @updatedAt

  versions MotifDirectiveVersion[]

  @@unique([workspaceId, key])
}

// Prior text of a directive, written before every edit.
model MotifDirectiveVersion {
  id          String   @id @default(cuid())
  directiveId String
  version     Int
  label       String   // voice/rhythm/evidence/cta snapshot label
  data        String   // JSON {label, summary, voice, rhythm, evidence, cta}
  editedById  String?
  createdAt   DateTime @default(now())

  directive MotifDirective @relation(fields: [directiveId], references: [id], onDelete: Cascade)

  @@index([directiveId, version])
}

// Workspace motif defaults by content tier and/or audience. The most specific
// match wins (tier+audience > tier > audience > catch-all).
model MotifDefault {
  id          String   @id @default(cuid())
  workspaceId String
  tier        Int?     // 1..4, null = any
  audience    String?  // free text, matched case-insensitively; null = any
  motifs      String   @default("[]") // JSON [{key, weight}]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId])
}

// Per-channel motif mapping: the article may be Informative while its LinkedIn
// variant leans Social (the framework already shifts "Social" onto social).
model PlatformMotif {
  id          String   @id @default(cuid())
  workspaceId String
  platform    String   // linkedin | x | instagram | facebook | video
  motifKey    String
  updatedAt   DateTime @updatedAt

  @@unique([workspaceId, platform])
}

// Truthfulness: [NEEDS SOURCE] claims become citation rows; publish is blocked
// while any are unverified (Spark hard constraint).
model BlogCitation {
  id        String   @id @default(cuid())
  postId    String
  claim     String
  sourceUrl String?
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

// ---- FR-3: SME knowledge profiles ---------------------------------------------
// The former 10-question expert interview, captured once and reused so drafts
// answer "as the expert would" instead of as a generic writer.
model SmeProfile {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  role        String?  // job title
  credentials String?  // certifications, licences, years in the field
  bio         String?
  // JSON keyed by the intake question id — see src/lib/sme.ts
  answers     String   @default("{}")
  alwaysSay   String?  // house lines this expert always uses
  neverSay    String?  // hard "never claim this" rules — enforced in prompts
  topics      String   @default("[]") // JSON array; used to auto-match a post to an expert
  status      String   @default("active") // active | archived
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  versions SmeProfileVersion[]

  @@index([workspaceId, status])
}

// Profiles are versioned over time (FR-3) — an expert's view changes and the
// draft that quoted the old one should stay explainable.
model SmeProfileVersion {
  id         String   @id @default(cuid())
  profileId  String
  version    Int
  data       String   // JSON snapshot of the whole profile
  editedById String?
  createdAt  DateTime @default(now())

  profile SmeProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, version])
}

// Blog idea engine (Spark FR-5): discovered → approved/rejected → drafted.
model BlogIdea {
  id        String   @id @default(cuid())
  workspaceId String
  topicId   String?  // workspace Topic this idea belongs to (steers discovery)
  title     String
  angle     String?  // the hook / why it works
  keyword   String?
  status    String   @default("discovered") // discovered | approved | rejected | drafted | merged
  source    String   @default("manual") // manual | ai | refresh | seasonal
  postId    String?  // set when drafted
  // FR-5 auto-tagging
  tier         Int?     // 1..4 content tier
  audience     String?
  targetPage   String?  // the service page this should support
  motifs       String   @default("[]") // JSON [{key, weight}] suggested blend
  seasonalHook String?  // the calendar moment this rides, if any
  // Deterministic priority: the score plus the breakdown that produced it, so
  // the ranking can always be explained rather than trusted.
  priority       Int?
  priorityReason String?
  // Dedupe against what's already published
  dedupeNote     String?  // "close to <published title>"
  refreshPostId  String?  // set when this should update a post instead of being new
  mergedIntoId   String?  // set when merged into another idea
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Deleting a topic must not delete the ideas that referenced it.
  topic     Topic?   @relation(fields: [topicId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status])
}

// WordPress connection (Spark FR-11); appPassword stored AES-GCM encrypted.
model WordPressConnection {
  id             String   @id @default(cuid())
  workspaceId    String   @unique
  baseUrl        String
  username       String
  encAppPassword String   // JSON {iv,tag,data} AES-256-GCM
  status         String   @default("connected") // connected | error
  // FR-7/FR-11 publish fidelity
  seoPlugin      String   @default("none") // none | yoast | rankmath | squirrly
  seoFieldMap    String   @default("{}")   // per-install overrides of the built-in key map
  defaultCategories String @default("[]")  // JSON array of category names
  defaultTags       String @default("[]")
  defaultAuthor  String?  // WP username or numeric id; blank = the connection's own user
  publishAsDraft Boolean  @default(false)  // draft-in-WP handoff instead of going live
  slugRules      String   @default("{}")   // JSON {maxWords, stripStopWords, prefix}
  updatedAt      DateTime @updatedAt
}

// Per-platform social copy for a published post (Spark FR-12).
model SocialVariant {
  id        String   @id @default(cuid())
  postId    String
  platform  String   // linkedin | x | instagram | facebook
  content   String
  status    String   @default("draft") // draft | approved | posted
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

// Manual analytics snapshots (Spark FR-14) until GSC/GA4 connectors land.
model BlogSnapshot {
  id          String   @id @default(cuid())
  postId      String
  capturedAt  DateTime @default(now())
  impressions Int?
  clicks      Int?
  position    Float?
  sessions    Int?
  conversions Int?

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

// The three-mode autonomy dial: one row per governed function per workspace.
model FunctionMode {
  id          String   @id @default(cuid())
  workspaceId String
  function    String   // ideation | blog_drafting | video_packaging | video_rendering | publishing | social
  mode        String   @default("manual") // manual | assisted | auto
  updatedAt   DateTime @updatedAt

  @@unique([workspaceId, function])
}

// ---- FR-16: notifications -------------------------------------------------------
// In-app first; email is opt-in per user per kind and rides the existing SMTP
// layer. Slack remains a connector, not built here.
model Notification {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String    // the recipient
  kind        String    // approval_needed | published | publish_failed | scheduled | assigned | comment
  title       String
  body        String?
  url         String?   // where to go to act on it
  entityType  String?
  entityId    String?
  readAt      DateTime?
  emailedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([workspaceId, userId, readAt])
}

model NotificationPreference {
  id          String  @id @default(cuid())
  workspaceId String
  userId      String
  kind        String
  inApp       Boolean @default(true)
  email       Boolean @default(false)
  updatedAt   DateTime @updatedAt

  @@unique([workspaceId, userId, kind])
}

// FR-10: inline review comments, optionally anchored to a passage.
model BlogComment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String?
  body      String
  anchor    String?  // the quoted passage or heading this refers to
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, resolved])
}

// ---- FR-15: existing-content audit ----------------------------------------------
// One row per audited URL. Recommendations only — nothing here deletes or
// rewrites anything, and a retire recommendation always carries redirect advice
// so ranking history survives.
model ContentAuditItem {
  id          String   @id @default(cuid())
  workspaceId String
  url         String
  title       String
  source      String   @default("wordpress") // wordpress | site_page | blog_post
  wordCount   Int?
  slopScore   Int?     // 0-100; higher is worse
  findings    String   @default("[]") // JSON list of what the detectors caught
  recommendation String @default("keep") // keep | rewrite | merge | retire
  reason      String?
  mergeTargetUrl String?
  /** Set when the workspace has performance data for this URL. */
  position    Float?
  status      String   @default("open") // open | actioned | dismissed
  auditedAt   DateTime @default(now())

  @@unique([workspaceId, url])
  @@index([workspaceId, status])
}

// ---- Reports hub -------------------------------------------------------------
// One row per (workspace, report). Stock reports exist implicitly from their
// code-side defaults; a row appears only once someone customizes (or creates a
// custom report), so stock defaults can keep improving without stale copies.
model ReportConfig {
  id            String   @id @default(cuid())
  workspaceId   String
  key           String   // stock key (traffic, content, …) or custom-<cuid>
  name          String
  description   String?
  blocks        String   @default("[]") // JSON ordered array of block keys
  dateRangeDays Int      @default(56)
  isCustom      Boolean  @default(false)
  updatedAt     DateTime @updatedAt

  @@unique([workspaceId, key])
}

// Workspace-level automation kill switch + audit trail (Spark NFR auditability).
model AutomationState {
  id          String  @id @default(cuid())
  workspaceId String  @unique
  globalPause Boolean @default(false)
  updatedAt   DateTime @updatedAt
}

// Phase 4 — a rendered (or queued) short-form video derived from content.
// Renders are queued by packaging (manual or autopilot) and processed by the
// video provider (mock by default; Veo when configured). costEstimate is a
// pre-render ceiling in USD, recorded so spend is visible before it happens.
model VideoRender {
  id           String   @id @default(cuid())
  workspaceId  String
  blogPostId   String?
  scriptId     String?
  topicId      String?  // workspace Topic; inherited from the source post when packaged
  title        String
  prompt       String   // the scene/visual prompt sent to the provider
  status       String   @default("queued") // queued | rendering | done | failed
  provider     String   @default("mock")
  seconds      Int      @default(8)
  aspect       String   @default("9:16") // short-form first
  outputUrl    String?
  error        String?
  costEstimate Float    @default(0)
  // Storyboard (slice 4): multi-scene plan. JSON [{prompt, seconds, text}].
  // `prompt` above stays the first scene for back-compat with older renders.
  scenes       String   @default("[]")
  srt          String?  // generated captions (SRT text)
  storedUrl    String?  // provider output persisted to StorageProvider (Veo URIs expire ~2d)
  voiceoverUrl String?  // TTS output, when a TTS provider is configured
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Deleting a topic must not delete the renders that referenced it.
  topic        Topic?   @relation(fields: [topicId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status])
}

model AuditLog {
  id          String   @id @default(cuid())
  workspaceId String
  actorId     String?  // null = system/AI
  action      String
  entityType  String
  entityId    String?
  meta        String   @default("{}") // JSON
  createdAt   DateTime @default(now())

  @@index([workspaceId, createdAt])
}

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

// Global key/value settings — currently used for in-app API key storage so admins
// can paste provider keys via UI instead of editing Railway env vars. Values are
// stored in plaintext; treat the DB as the secret boundary (same trust level as env).
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Workspace-scoped settings (API keys, SMTP, provider switches, branding).
// Resolution everywhere is: WorkspaceSetting → global Setting → env var, so
// each company can bring its own keys while the platform's keys stay as the
// fallback for workspaces that haven't configured their own.
model WorkspaceSetting {
  workspaceId String
  key         String
  value       String
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@id([workspaceId, key])
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  emailVerified DateTime?
  name          String?
  image         String?
  // Credentials (email/password)
  passwordHash  String?
  createdAt     DateTime      @default(now())
  lastActivityAt DateTime?

  memberships   Membership[]
  accounts      Account[]
  sessions      Session[]
  authoredChats Chat[]
  authoredScripts Script[]
  assignedTasks Task[]        @relation("TaskAssignee")
  projectAssignments ProjectAssignee[]
}

model Membership {
  id          String    @id @default(cuid())
  userId      String
  workspaceId String
  role        Role      @default(EDITOR)
  status      String    @default("active") // active | revoked
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model Invitation {
  id          String    @id @default(cuid())
  workspaceId String
  email       String
  role        Role      @default(EDITOR)
  token       String    @unique
  invitedById String?
  acceptedAt  DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// Auth.js core tables (Account / Session / VerificationToken)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// ──────────────────────────────────────────────────────────────────────────
// Channels & creator-modeling (FR-CHAN-*, FR-VOICE-*, FR-AUD-*)
// ──────────────────────────────────────────────────────────────────────────

model Channel {
  id                 String   @id @default(cuid())
  workspaceId        String
  name               String
  nicheDescription   String?
  presentationStyle  String?  // "personality" | "faceless"
  linkedYoutubeId    String?
  linkedYoutubeHandle String?
  differentiation    String?
  defaultModel       String?
  defaultLanguage    String   @default("en")
  defaultTemplateId  String?
  accentColor        String?  // matches mockup per-module accent
  thumbnailConfig    String?  // FR-THUMB-06 — brand assets + style prefs (JSON)
  limitThumbnailsPerMonth Int? // FR-THUMB-07 — optional per-channel cap
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  workspace          Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  voiceProfiles      VoiceProfile[]
  audience           AudienceAvatar?
  competitors        Competitor[]
  memory             ChannelMemoryEntry[]
  ideas              Idea[]
  scripts            Script[]
  chats              Chat[]
  research           ResearchSource[]
  templates          Template[]
  contentProjects    ContentProject[]
  submissions        AudienceSubmission[]
  channelStats       ChannelStat[]
  thumbnails         Thumbnail[]
  assets             Asset[]
  wikiDocs           WikiDoc[]
}

model VoiceProfile {
  id          String   @id @default(cuid())
  channelId   String
  label       String
  isDefault   Boolean  @default(false)
  // Per FR-VOICE-04: archetype, delivery, rhetoric, diction, additional settings
  data        String   // JSON
  samples     String   @default("[]") // JSON array of writing samples
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  channel     Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
}

model AudienceAvatar {
  id              String   @id @default(cuid())
  channelId       String   @unique
  demographics    String   @default("{}")
  psychographics  String   @default("{}")
  onlineBehavior  String   @default("{}")
  offlineBehavior String   @default("{}")
  keyQuestions    String   @default("[]")
  photoUrl        String?
  updatedAt       DateTime @updatedAt

  channel         Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
}

model Competitor {
  id              String   @id @default(cuid())
  channelId       String
  intelChannelId  String?
  youtubeHandle   String?
  youtubeId       String?
  metricsSnapshot String   @default("{}") // JSON
  createdAt       DateTime @default(now())

  channel         Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  intelChannel    IntelChannel? @relation(fields: [intelChannelId], references: [id])
}

model ChannelMemoryEntry {
  id        String   @id @default(cuid())
  channelId String
  body      String
  createdAt DateTime @default(now())

  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
}

// ──────────────────────────────────────────────────────────────────────────
// Intel / research database (FR-INTEL-*)
// ──────────────────────────────────────────────────────────────────────────

model IntelChannel {
  id              String   @id @default(cuid())
  youtubeId       String   @unique
  handle          String?
  name            String?
  subscribers     Int?
  totalViews      BigInt?
  videoCount      Int?
  uploadFrequency Float?   // videos per week
  velocityScore   Float?
  language        String?
  category        String?
  thumbnailUrl    String?
  lastIndexedAt   DateTime?
  createdAt       DateTime @default(now())

  videos          IntelVideo[]
  competitorRefs  Competitor[]
  bookmarks       Bookmark[]
}

model IntelVideo {
  id              String   @id @default(cuid())
  intelChannelId  String
  youtubeId       String   @unique
  title           String
  description     String?
  publishedAt     DateTime?
  durationSeconds Int?
  views           BigInt?
  likes           Int?
  comments        Int?
  thumbnailUrl    String?
  transcript      String?  // may be large
  outlierScore    Float?
  viewsPerSub     Float?
  format          String?  // "short" | "long"
  createdAt       DateTime @default(now())

  intelChannel    IntelChannel @relation(fields: [intelChannelId], references: [id], onDelete: Cascade)
  bookmarks       Bookmark[]
  sourcedIdeas    Idea[]
}

// ──────────────────────────────────────────────────────────────────────────
// Ideas, chat, scripts, templates (FR-IDEA, FR-CHAT, FR-CANV, FR-SB, FR-TMPL)
// ──────────────────────────────────────────────────────────────────────────

model Idea {
  id             String   @id @default(cuid())
  channelId      String
  title          String
  // Free-text subject (usually the channel's niche) — predates the structured
  // workspace Topic below and is kept as-is; `topicId` is the real link.
  topic          String?
  topicId        String?  // workspace Topic (the channel's workspace owns it)
  strategy       String?  // the hook / why it works
  sourceVideoId  String?
  outlierScore   Float?
  suggestedLength String?
  status         String   @default("new") // new | in_progress | scripted | archived
  merit          String?  // pillar | trending | experiment
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  channel        Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sourceVideo    IntelVideo? @relation(fields: [sourceVideoId], references: [id])
  // Named `workspaceTopic` because the free-text `topic` field above owns the
  // plain name. Deleting a topic must not delete the ideas that used it.
  workspaceTopic Topic?   @relation(fields: [topicId], references: [id], onDelete: SetNull)
  scripts        Script[]
}

model Chat {
  id          String   @id @default(cuid())
  channelId   String
  userId      String
  type        String   @default("ideation") // ideation | canvas
  title       String?
  scriptId    String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  channel     Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id])
  messages    ChatMessage[]
  contextItems ChatContext[]
  script      Script?  @relation(fields: [scriptId], references: [id])
}

model ChatMessage {
  id        String   @id @default(cuid())
  chatId    String
  role      String   // "user" | "assistant" | "system"
  content   String
  model     String?
  createdAt DateTime @default(now())

  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
}

model ChatContext {
  id        String   @id @default(cuid())
  chatId    String
  kind      String   // youtube_url | web_url | upload | text
  ref       String   // url or upload id
  metadata  String   @default("{}")
  createdAt DateTime @default(now())

  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
}

model Script {
  id             String   @id @default(cuid())
  channelId      String
  authorId       String?
  ideaId         String?
  title          String
  workflow       String   @default("canvas") // canvas | builder
  templateId     String?
  voiceProfileId String?
  model          String?  // model used for last gen
  language       String   @default("en")
  status         String   @default("draft")
  outline        String?  // JSON plan
  builderSteps   String?  // JSON for classic builder
  body           String?  // current rich text / markdown
  wordCount      Int      @default(0)
  durationSeconds Int     @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  channel        Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author         User?    @relation(fields: [authorId], references: [id])
  idea           Idea?    @relation(fields: [ideaId], references: [id])
  template       Template? @relation(fields: [templateId], references: [id])
  versions       ScriptVersion[]
  research       ResearchSource[]
  thumbnails     Thumbnail[]
  agentRuns      AgentRun[]
  chat           Chat?
  contentProject ContentProject?
}

model ScriptVersion {
  id        String   @id @default(cuid())
  scriptId  String
  label     String?  // "outline approved" | "post-humanize" etc.
  body      String?
  outline   String?
  wordCount Int      @default(0)
  createdAt DateTime @default(now())

  script    Script   @relation(fields: [scriptId], references: [id], onDelete: Cascade)
}

model Template {
  id        String   @id @default(cuid())
  channelId String?  // null = built-in/global
  name      String
  kind      String   // "long" | "short"
  source    String   @default("built-in") // built-in | cloned | custom
  structure String   // JSON: sections, pacing, transitions
  createdAt DateTime @default(now())

  channel   Channel? @relation(fields: [channelId], references: [id], onDelete: Cascade)
  scripts   Script[]
}

// ──────────────────────────────────────────────────────────────────────────
// Research, thumbnails, agent runs, bookmarks, usage (FR-RES, FR-THUMB, FR-AGENT)
// ──────────────────────────────────────────────────────────────────────────

model ResearchSource {
  id          String   @id @default(cuid())
  channelId   String
  scriptId    String?
  kind        String   // youtube | web | pdf | word | text | image
  ref         String   // URL or upload key
  title       String?
  content     String?  // extracted text / transcript
  wordCount   Int      @default(0)
  starred     Boolean  @default(false)
  createdAt   DateTime @default(now())

  channel     Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  script      Script?  @relation(fields: [scriptId], references: [id], onDelete: Cascade)
}

model Thumbnail {
  id        String   @id @default(cuid())
  channelId String
  scriptId  String?
  ideaId    String?
  title     String?
  mode      String   // brainstorm | clone
  concepts  String   @default("[]") // JSON
  renderUrl String?
  ctrScore  Float?
  createdAt DateTime @default(now())

  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  script    Script?  @relation(fields: [scriptId], references: [id])
}

model AgentRun {
  id        String   @id @default(cuid())
  scriptId  String
  status    String   @default("queued") // queued | running | succeeded | failed | cancelled
  steps     String   @default("[]") // JSON pipeline state
  progress  Float    @default(0)
  retries   Int      @default(0)
  startedAt DateTime?
  endedAt   DateTime?
  error     String?

  script    Script   @relation(fields: [scriptId], references: [id], onDelete: Cascade)
}

model Bookmark {
  id              String   @id @default(cuid())
  workspaceId     String
  intelChannelId  String?
  intelVideoId    String?
  tags            String   @default("[]")
  notes           String?
  createdAt       DateTime @default(now())

  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  intelChannel    IntelChannel? @relation(fields: [intelChannelId], references: [id])
  intelVideo      IntelVideo?   @relation(fields: [intelVideoId], references: [id])
}

model UsageLog {
  id          String   @id @default(cuid())
  workspaceId String
  actorId     String?  // userId
  action      String   // script.generate | thumbnail.generate | agent.run | chat.message
  model       String?
  tokens      Int?
  words       Int?
  createdAt   DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ──────────────────────────────────────────────────────────────────────────
// Production pipeline, tasks, calendar, assets (FR-PIPE, FR-TASK, FR-CAL, FR-ASSET, FR-SWIPE, FR-WIKI)
// ──────────────────────────────────────────────────────────────────────────

model ContentProject {
  id             String   @id @default(cuid())
  channelId      String
  scriptId       String?  @unique
  parentId       String?  // for repurposing
  title          String
  format         String?  // long | short | repurpose
  status         String   @default("idea") // idea | research_writing | recording | editing | scheduled | published
  editStatus     String?  // assembly | rough_cut | vfx | sound_music | color
  publishDate    DateTime?
  ideaMerit      String?
  keywords       String   @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  channel        Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  script         Script?  @relation(fields: [scriptId], references: [id])
  parent         ContentProject? @relation("Repurposed", fields: [parentId], references: [id])
  derivatives    ContentProject[] @relation("Repurposed")
  assignees      ProjectAssignee[]
  tasks          Task[]
  assetLinks     AssetLink[]
}

model ProjectAssignee {
  id              String   @id @default(cuid())
  contentProjectId String
  userId          String
  role            String?  // writer | host | editor

  contentProject  ContentProject @relation(fields: [contentProjectId], references: [id], onDelete: Cascade)
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([contentProjectId, userId, role])
}

model Task {
  id              String   @id @default(cuid())
  workspaceId     String
  contentProjectId String?
  title           String
  description     String?
  assigneeId      String?
  dueDate         DateTime?
  status          String   @default("todo") // todo | in_progress | done
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contentProject  ContentProject? @relation(fields: [contentProjectId], references: [id])
  assignee        User?     @relation("TaskAssignee", fields: [assigneeId], references: [id])
}

model Asset {
  id          String   @id @default(cuid())
  channelId   String?  // optional channel scope
  kind        String   // broll | stock | animation | upload | link
  name        String
  url         String?
  uploadKey   String?
  favorite    Boolean  @default(false)
  tags        String   @default("[]")
  source      String?  // "premiere_marker" | "frameio" | "upload"
  createdAt   DateTime @default(now())

  channel     Channel? @relation(fields: [channelId], references: [id], onDelete: Cascade)
  links       AssetLink[]
}

model AssetLink {
  id              String @id @default(cuid())
  assetId         String
  contentProjectId String

  asset           Asset           @relation(fields: [assetId], references: [id], onDelete: Cascade)
  contentProject  ContentProject  @relation(fields: [contentProjectId], references: [id], onDelete: Cascade)

  @@unique([assetId, contentProjectId])
}

model Swipe {
  id          String   @id @default(cuid())
  workspaceId String
  channelId   String?
  imageUrl    String
  title       String?
  sourceUrl   String?
  tags        String   @default("[]")
  kind        String?  // thumbnail | set | landing
  createdAt   DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model WikiDoc {
  id          String   @id @default(cuid())
  workspaceId String
  channelId   String?
  title       String
  body        String
  checklist   String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channel     Channel?  @relation(fields: [channelId], references: [id], onDelete: Cascade)
}

// ──────────────────────────────────────────────────────────────────────────
// Growth loop (FR-PERF, FR-SUB)
// ──────────────────────────────────────────────────────────────────────────

model AudienceSubmission {
  id          String   @id @default(cuid())
  channelId   String
  submitter   String?
  topic       String
  notes       String?
  status      String   @default("new") // new | reviewed | promoted | rejected
  createdAt   DateTime @default(now())

  channel     Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
}

model ChannelStat {
  id          String   @id @default(cuid())
  channelId   String
  videoYoutubeId String?
  views       BigInt?
  retentionProxy Float?
  engagement  Float?
  capturedAt  DateTime @default(now())

  channel     Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
}

// Unipile-connected accounts (email + social), one row per connected mailbox or
// social profile, scoped to the workspace that connected it. The account_id is
// Unipile's; sending email / posting resolves the workspace's account here.
// Platform holds ONE Unipile API key/DSN (Settings unipile:api_key / unipile:dsn)
// under which every tenant's accounts are connected — the multi-tenant fit.
model UnipileAccount {
  id            String   @id @default(cuid())
  workspaceId   String
  accountId     String   // Unipile account id
  kind          String   // email | social
  provider      String   // GOOGLE | OUTLOOK | IMAP | MAIL | LINKEDIN | INSTAGRAM | X | ...
  name          String?  // email address or social profile name (display)
  isDefault     Boolean  @default(false) // default sender for its kind+provider
  status        String   @default("connected") // connected | error | disconnected
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, accountId])
  @@index([workspaceId, kind])
}

// ---- Social scheduler (Hootsuite/Buffer-style) ------------------------------
// A composed post fanned out to one or more connected social accounts, publish
// now or scheduled. Publishing goes through Unipile; each target carries its own
// status so a 3-network post records exactly which legs succeeded.
model SocialPost {
  id          String   @id @default(cuid())
  workspaceId String
  createdById String?
  topicId     String?  // optional workspace Topic this post belongs to
  text        String
  mediaKeys   String   @default("[]") // JSON array of StorageProvider keys
  scheduledAt DateTime?               // null = draft / post-now
  // draft | scheduled | publishing | posted | partial | failed
  status      String   @default("draft")
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  // Deleting a topic must not delete the posts that referenced it.
  topic       Topic?             @relation(fields: [topicId], references: [id], onDelete: SetNull)
  targets     SocialPostTarget[]

  @@index([workspaceId, status])
  @@index([status, scheduledAt])
  @@index([workspaceId, topicId])
}

model SocialPostTarget {
  id              String    @id @default(cuid())
  postId          String
  provider        String    // LINKEDIN | X | INSTAGRAM | ...
  unipileAccountId String   // Unipile account id (resolved at publish)
  accountName     String?
  // Per-network overrides — null falls back to the post's base at publish.
  text            String?
  mediaKeys       String?   // JSON array of storage keys; null = use base media
  status          String    @default("pending") // pending | posted | failed
  providerPostId  String?
  error           String?
  postedAt        DateTime?

  post SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

// Workspace topics/themes — the subjects this company publishes about. Feeds
// ideation and the social composer. Distinct from Keyword (search phrases with
// tiers/intent) and from SmeProfile.topics (what one persona is expert in).
model Topic {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  description String?
  keywords    String   @default("[]") // JSON array of related phrases
  status      String   @default("active") // active | archived
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  socialPosts SocialPost[]
  blogPosts     BlogPost[]
  blogIdeas     BlogIdea[]
  channelIdeas  Idea[]
  videoRenders  VideoRender[]

  @@unique([workspaceId, name])
  @@index([workspaceId, status])
}
